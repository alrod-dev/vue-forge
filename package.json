{
  "name": "vue-forge",
  "version": "1.0.0",
  "description": "Enterprise Vue 3 Component Library - Production-grade components, composables, and theming system",
  "author": "Alfredo Wiesner <alrod.dev@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/style.css",
    "./composables": {
      "import": "./dist/composables.mjs",
      "require": "./dist/composables.js",
      "types": "./dist/composables.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "vite build --mode lib",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "type-check": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "vue": "^3.5.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^1.1.0",
    "@vue/test-utils": "^2.4.3",
    "@vueuse/core": "^10.9.0",
    "@vueuse/components": "^10.9.0",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "happy-dom": "^12.10.3",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "vitepress": "^1.0.1",
    "vitest": "^1.1.0",
    "vue-tsc": "^1.8.22"
  }
}
